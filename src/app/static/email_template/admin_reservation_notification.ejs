<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">

<head>
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8" />
    <meta name="color-scheme" content="light dark" />
    <meta name="supported-color-schemes" content="light dark" />
    <title></title>
    <style type="text/css" rel="stylesheet" media="all">
        @import url("https://fonts.googleapis.com/css?family=Nunito+Sans:400,700&display=swap");

        body {
            width: 100% !important;
            height: 100%;
            margin: 0;
            -webkit-text-size-adjust: none;
            background-color: #f2f4f6;
            color: #51545e;
            font-family: "Nunito Sans", Helvetica, Arial, sans-serif;
        }

        td {
            word-break: break-word;
        }

        h1 {
            margin-top: 0;
            color: #333333;
            font-size: 22px;
            font-weight: bold;
            text-align: left;
        }

        p {
            margin: 0.4em 0 1.1875em;
            font-size: 16px;
            line-height: 1.625;
            color: #51545e;
        }

        .email-wrapper {
            width: 100%;
            margin: 0;
            padding: 0;
            background-color: #f2f4f6;
        }

        .email-body_inner {
            width: 570px;
            margin: 0 auto;
            padding: 0;
            background-color: #ffffff;
            border-top: 6px solid #2563eb; 
        }

        .content-cell {
            padding: 45px;
        }

        .details-table {
            width: 100%;
            margin: 20px 0;
            border-collapse: collapse;
        }

        .details-row {
            border-bottom: 1px solid #eaeaec;
        }

        .details-label {
            padding: 12px 0;
            color: #85878e;
            font-size: 13px;
            font-weight: bold;
            text-transform: uppercase;
            width: 35%;
        }

        .details-value {
            padding: 12px 0;
            color: #333333;
            font-size: 15px;
            text-align: left;
        }

        .action-banner {
            background-color: #eff6ff;
            border-left: 4px solid #2563eb;
            padding: 15px;
            border-radius: 4px;
            margin-bottom: 25px;
        }

        @media only screen and (max-width: 600px) {
            .email-body_inner {
                width: 100% !important;
            }
        }

        @media (prefers-color-scheme: dark) {
            body, .email-body_inner, .email-wrapper {
                background-color: #222222 !important;
                color: #fff !important;
            }
            p, h1, .details-value {
                color: #fff !important;
            }
            .details-row {
                border-bottom: 1px solid #444444 !important;
            }
            .action-banner {
                background-color: #1e3a8a !important;
            }
        }
    </style>
</head>

<body>
    <table class="email-wrapper" width="100%" cellpadding="0" cellspacing="0" role="presentation">
        <tr>
            <td align="center">
                <table class="email-body_inner" align="center" width="570" cellpadding="0" cellspacing="0" role="presentation">
                    <tr>
                        <td class="content-cell">
                            <div style="text-align: center; margin-bottom: 20px;">
                                <h2 style="color: #dc2626; margin: 0; font-size: 24px; letter-spacing: 1px;">PATTY BRO'S</h2>
                            </div>

                            <h1>New Reservation Request</h1>
                            <p><%= title %></p>
                            
                            <div class="action-banner">
                                <p style="margin: 0; font-size: 14px; color: #dc2626; line-height: 1.5;">
                                    <strong>Action Required:</strong> Please log into the admin dashboard to review, assign capacity, and update this reservation's status to <strong>Confirmed</strong> or <strong>Cancelled</strong>.
                                </p>
                            </div>

                            <h3 style="color: #333333; font-size: 14px; font-weight: bold; margin-bottom: 10px; border-bottom: 2px solid #dc2626; padding-bottom: 5px; text-transform: uppercase; letter-spacing: 0.5px;">Reservation Specifications</h3>
                            
                            <table class="details-table" role="presentation">
                                <tr class="details-row">
                                    <td class="details-label">Customer</td>
                                    <td class="details-value"><strong><%= order.customerName %></strong></td>
                                </tr>
                                <tr class="details-row">
                                    <td class="details-label">Party Size</td>
                                    <td class="details-value"><%= order.partySize %> Guests</td>
                                </tr>
                                <tr class="details-row">
                                    <td class="details-label">Target Date</td>
                                    <td class="details-value">
                                        <%= new Date(order.reservationDate).toLocaleDateString('en-GB', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
                                    </td>
                                </tr>
                                <tr class="details-row">
                                    <td class="details-label">Requested Time</td>
                                    <td class="details-value"><%= order.preferredTime %></td>
                                </tr>
                                <tr class="details-row">
                                    <td class="details-label">Phone Number</td>
                                    <td class="details-value"><%= order.customerPhone %></td>
                                </tr>
                                <tr class="details-row">
                                    <td class="details-label">Email Address</td>
                                    <td class="details-value"><%= order.customerEmail %></td>
                                </tr>
                                <tr class="details-row">
                                    <td class="details-label">System Status</td>
                                    <td class="details-value" style="color: #d97706; font-weight: bold;"><%= order.status.toUpperCase() %></td>
                                </tr>
                            </table>

                            
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>

</html>